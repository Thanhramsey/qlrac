# ==============================================================================
# QUẢN LÝ BIẾN MÔI TRƯỜNG DỰ ÁN (LOCAL DEV vs PRODUCTION DEPLOY)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. BACKEND (NestJS) - File: .env (Thư mục gốc)
# ------------------------------------------------------------------------------
# [Local Dev] Kết nối PostgreSQL Local:
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/db_quanly_thurac?schema=public"

# [Deploy Railway] Nhập biến DATABASE_URL trên Railway Dashboard bằng "Add Reference" từ service PostgreSQL.

JWT_SECRET="qltrac_super_secret_key_change_in_production"
JWT_EXPIRES_IN="1d"
JWT_ACCESS_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="qltrac_refresh_super_secret_key_change_in_production"
JWT_REFRESH_EXPIRES_IN="7d"

# ------------------------------------------------------------------------------
# 2. FRONTEND (Vite / React) - Thư mục: admin-frontend/
# ------------------------------------------------------------------------------
# [Local Dev] File admin-frontend/.env.development:
#   VITE_API_BASE_URL=/api    (tự động proxy qua http://localhost:3000)
#
# [Deploy Vercel] File admin-frontend/.env.production (hoặc Vercel Dashboard):
#   VITE_API_BASE_URL=https://qlrac-production.up.railway.app

# ------------------------------------------------------------------------------
# 3. MOBILE APP (Expo) - Thư mục: mobile/
# ------------------------------------------------------------------------------
# [Local Dev] File mobile/.env (Chạy Expo Go / Emulator nối Backend Local):
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:3000   (Expo tự lấy IP máy tính)
#
# [Deploy / Test Railway] File mobile/.env:
#   EXPO_PUBLIC_API_BASE_URL=https://qlrac-production.up.railway.app
#
# [EAS Build APK] Cấu hình qua lệnh:
#   npx eas-cli env:update --variable-name EXPO_PUBLIC_API_BASE_URL --value "https://qlrac-production.up.railway.app" --environment preview
