# ============================================
# BACKEND ENVIRONMENT VARIABLES (Railway)
# ============================================

# Database - Sao chép từ Railway PostgreSQL service
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT Secrets - Đổi thành chuỗi bí mật mạnh hơn khi production!
JWT_SECRET="your_super_strong_jwt_secret_here"
JWT_EXPIRES_IN="1d"
JWT_ACCESS_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="your_super_strong_refresh_secret_here"
JWT_REFRESH_EXPIRES_IN="7d"

# Port - Railway tự động set biến PORT, không cần đổi
PORT=3000

# Node environment
NODE_ENV="production"
