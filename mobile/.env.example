# ================================================================
# MOBILE APP ENVIRONMENT VARIABLES (Expo)
# ================================================================
# Copy file này thành .env trong thư mục mobile/

# Option A: Kết nối Backend Local trên máy tính (Expo tự động nhận diện IP)
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Option B: Kết nối Backend Production trên Railway
EXPO_PUBLIC_API_BASE_URL=https://qlrac-production.up.railway.app
