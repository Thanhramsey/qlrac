// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CollectionStatus {
  PENDING
  COMPLETED
  MISSED

  @@map("collection_status")
}

enum InvoicePaymentStatus {
  UNPAID
  PAID
  OVERDUE

  @@map("invoice_payment_status")
}

model Household {
  id           Int          @id @default(autoincrement()) @map("id")
  maHoDan      String       @unique @map("ma_ho_dan")
  tenChuHo     String       @map("ten_chu_ho")
  diaChi       String       @map("dia_chi")
  soDienThoai  String       @map("so_dien_thoai")
  tuyenThuRacId Int         @map("tuyen_thu_rac_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  tuyenThuRac  Route        @relation(fields: [tuyenThuRacId], references: [id])
  collections  Collection[]
  invoices     Invoice[]

  @@index([tuyenThuRacId])
  @@map("households")
}

model Route {
  id         Int          @id @default(autoincrement()) @map("id")
  maTuyen    String       @unique @map("ma_tuyen")
  tenTuyen   String       @map("ten_tuyen")
  khuVuc     String       @map("khu_vuc")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  households Household[]
  collections Collection[]

  @@map("routes")
}

model Collection {
  id          Int              @id @default(autoincrement()) @map("id")
  householdId Int              @map("household_id")
  routeId     Int              @map("route_id")
  ngayThuGom  DateTime         @map("ngay_thu_gom")
  trangThai   CollectionStatus @default(PENDING) @map("trang_thai")
  ghiChu      String?          @map("ghi_chu")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])
  route     Route     @relation(fields: [routeId], references: [id])

  @@index([householdId])
  @@index([routeId])
  @@index([ngayThuGom, trangThai])
  @@map("collections")
}

model Invoice {
  id                 Int                  @id @default(autoincrement()) @map("id")
  householdId        Int                  @map("household_id")
  kyHoaDon           String               @map("ky_hoa_don")
  tongTien           Decimal              @db.Decimal(18, 2) @map("tong_tien")
  thue               Decimal              @db.Decimal(18, 2) @map("thue")
  trangThaiThanhToan InvoicePaymentStatus @default(UNPAID) @map("trang_thai_thanh_toan")
  hanThanhToan       DateTime             @map("han_thanh_toan")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])

  @@index([householdId])
  @@index([kyHoaDon, trangThaiThanhToan])
  @@map("invoices")
}

model Role {
  code      String   @id @map("code")
  label     String   @map("label")
  moTa      String?  @map("mo_ta")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

model User {
  id          Int       @id @default(autoincrement()) @map("id")
  taiKhoan    String    @unique @map("tai_khoan")
  matKhauHash String    @map("mat_khau_hash")
  refreshTokenHash String? @map("refresh_token_hash")
  hoVaTen     String    @map("ho_va_ten")
  ngaySinh    DateTime? @map("ngay_sinh")
  gioiTinh    String?   @map("gioi_tinh")
  soDienThoai String    @map("so_dien_thoai")
  soGiayTo    String    @unique @map("so_giay_to")
  diaChi      String?   @map("dia_chi")
  email       String?   @map("email")
  roleCode    String    @default("STAFF") @map("role_code")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  role Role @relation(fields: [roleCode], references: [code])

  @@index([soDienThoai])
  @@index([roleCode])
  @@map("users")
}