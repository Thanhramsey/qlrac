// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CollectionStatus {
  PENDING
  COMPLETED
  MISSED

  @@map("collection_status")
}

enum InvoicePaymentStatus {
  UNPAID
  PAID
  OVERDUE
  PUBLISHED

  @@map("invoice_payment_status")
}

model Household {
  id              Int             @id @default(autoincrement()) @map("id")
  maHoDan         String          @unique @map("ma_ho_dan")
  tenChuHo        String          @map("ten_chu_ho")
  diaChi          String          @map("dia_chi")
  soDienThoai     String          @map("so_dien_thoai")
  soGiayTo        String          @unique @map("so_giay_to")
  ngayCapGiayTo   DateTime?       @map("ngay_cap_giay_to")
  maSoThue        String?         @map("ma_so_thue")
  serviceCatalogId Int?           @map("service_catalog_id")
  tuyenThuRacId   Int             @map("tuyen_thu_rac_id")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  serviceCatalog  ServiceCatalog? @relation(fields: [serviceCatalogId], references: [id])
  tuyenThuRac     Route           @relation(fields: [tuyenThuRacId], references: [id])
  collections     Collection[]
  invoices        Invoice[]

  @@index([serviceCatalogId])
  @@index([tuyenThuRacId])
  @@index([isActive])
  @@map("households")
}

model Route {
  id         Int          @id @default(autoincrement()) @map("id")
  maTuyen    String       @unique @map("ma_tuyen")
  tenTuyen   String       @map("ten_tuyen")
  khuVuc     String       @map("khu_vuc")
  localityId Int?         @map("locality_id")
  staffId    Int?         @map("staff_id")
  isActive   Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  households Household[]
  collections Collection[]
  locality   Locality?    @relation(fields: [localityId], references: [id])
  staff      User?        @relation("route_staff", fields: [staffId], references: [id])

  @@index([localityId])
  @@index([staffId])
  @@index([isActive])
  @@map("routes")
}

model Province {
  id        Int       @id @default(autoincrement()) @map("id")
  maTinh    String    @unique @map("ma_tinh")
  tenTinh   String    @map("ten_tinh")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  wards Ward[]

  @@index([isActive])
  @@map("provinces")
}

model Ward {
  id         Int       @id @default(autoincrement()) @map("id")
  provinceId Int       @map("province_id")
  maPhuongXa String    @map("ma_phuong_xa")
  tenPhuongXa String   @map("ten_phuong_xa")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  province   Province  @relation(fields: [provinceId], references: [id])
  localities Locality[]

  @@unique([provinceId, maPhuongXa])
  @@index([provinceId])
  @@index([isActive])
  @@map("wards")
}

model Locality {
  id         Int      @id @default(autoincrement()) @map("id")
  wardId     Int      @map("ward_id")
  maThonXomTo String  @map("ma_thon_xom_to")
  tenThonXomTo String @map("ten_thon_xom_to")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ward Ward   @relation(fields: [wardId], references: [id])
  routes Route[]

  @@unique([wardId, maThonXomTo])
  @@index([wardId])
  @@index([isActive])
  @@map("localities")
}

model Collection {
  id          Int              @id @default(autoincrement()) @map("id")
  householdId Int              @map("household_id")
  routeId     Int              @map("route_id")
  ngayThuGom  DateTime         @map("ngay_thu_gom")
  trangThai   CollectionStatus @default(PENDING) @map("trang_thai")
  ghiChu      String?          @map("ghi_chu")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])
  route     Route     @relation(fields: [routeId], references: [id])

  @@index([householdId])
  @@index([routeId])
  @@index([ngayThuGom, trangThai])
  @@index([isActive])
  @@map("collections")
}

model Invoice {
  id                 Int                  @id @default(autoincrement()) @map("id")
  householdId        Int                  @map("household_id")
  kyHoaDon           String               @map("ky_hoa_don")
  tongTien           Decimal              @db.Decimal(18, 2) @map("tong_tien")
  thue               Decimal              @db.Decimal(18, 2) @map("thue")
  trangThaiThanhToan InvoicePaymentStatus @default(UNPAID) @map("trang_thai_thanh_toan")
  hanThanhToan       DateTime             @map("han_thanh_toan")
  paymentDate        DateTime?            @map("payment_date")
  paymentNote        String?              @map("payment_note")
  receiptImageUrl    String?              @map("receipt_image_url")
  invoiceSerial      String?              @map("invoice_serial")
  invoiceFkey        String?              @map("invoice_fkey")
  invoiceIssuedAt    DateTime?            @map("invoice_issued_at")
  invoicePublishStatus String?            @map("invoice_publish_status")
  invoicePublishMessage String?           @map("invoice_publish_message")
  publishedById      Int?                 @map("published_by_id")
  publishedByName    String?              @map("published_by_name")
  collectedById      Int?                 @map("collected_by_id")
  collectedByName    String?              @map("collected_by_name")
  mergedPeriodCodes  String?              @map("merged_period_codes")
  isActive           Boolean              @default(true) @map("is_active")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])

  @@index([householdId])
  @@index([kyHoaDon, trangThaiThanhToan])
  @@index([publishedById])
  @@index([collectedById])
  @@index([isActive])
  @@map("invoices")
}

model BillingPeriod {
  id              Int      @id @default(autoincrement()) @map("id")
  maKy            String   @unique @map("ma_ky")
  tenKy           String   @map("ten_ky")
  ngayBatDau      DateTime @map("ngay_bat_dau")
  ngayKetThuc     DateTime @map("ngay_ket_thuc")
  isClosed        Boolean  @default(false) @map("is_closed")
  isAutoGenerated Boolean  @default(false) @map("is_auto_generated")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([ngayBatDau, ngayKetThuc])
  @@index([isClosed])
  @@index([isActive])
  @@map("billing_periods")
}

model BillingPeriodConfig {
  id                Int      @id @default(1) @map("id")
  autoCreateEnabled Boolean  @default(true) @map("auto_create_enabled")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("billing_period_configs")
}

model ServiceCatalog {
  id          Int      @id @default(autoincrement()) @map("id")
  maDichVu    String   @unique @map("ma_dich_vu")
  tenDichVu   String   @map("ten_dich_vu")
  giaDichVu   Decimal  @db.Decimal(18, 2) @map("gia_dich_vu")
  thuePhanTram Decimal @db.Decimal(5, 2) @map("thue_phan_tram")
  isActive    Boolean  @default(true) @map("is_active")
  ghiChu      String?  @map("ghi_chu")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  households Household[]

  @@index([isActive])
  @@map("service_catalogs")
}

model Role {
  code      String   @id @map("code")
  label     String   @map("label")
  moTa      String?  @map("mo_ta")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  roleMenuPermissions RoleMenuPermission[]
  rolePermissions     RolePermission[]

  @@map("roles")
}

model Menu {
  id         Int      @id @default(autoincrement()) @map("id")
  menuKey    String   @unique @map("menu_key")
  tenMenu    String   @map("ten_menu")
  routePath  String?  @map("route_path")
  parentId   Int?     @map("parent_id")
  sortOrder  Int      @default(0) @map("sort_order")
  viewMobile Boolean  @default(false) @map("view_mobile")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  parent              Menu?                @relation("menu_hierarchy", fields: [parentId], references: [id])
  children            Menu[]               @relation("menu_hierarchy")
  roleMenuPermissions RoleMenuPermission[]

  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
  @@map("menus")
}

model RoleMenuPermission {
  roleCode  String   @map("role_code")
  menuId    Int      @map("menu_id")
  createdAt DateTime @default(now()) @map("created_at")

  role Role @relation(fields: [roleCode], references: [code])
  menu Menu @relation(fields: [menuId], references: [id])

  @@id([roleCode, menuId])
  @@index([menuId])
  @@map("role_menu_permissions")
}

model UserActionLog {
  id          Int      @id @default(autoincrement()) @map("id")
  userId      Int?     @map("user_id")
  taiKhoan    String?  @map("tai_khoan")
  hoVaTen     String?  @map("ho_va_ten")
  roleCode    String?  @map("role_code")
  httpMethod  String   @map("http_method")
  moduleKey   String?  @map("module_key")
  action      String   @map("action")
  endpoint    String   @map("endpoint")
  statusCode  Int      @map("status_code")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  requestData Json?    @map("request_data")
  errorMessage String? @map("error_message")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([moduleKey])
  @@index([httpMethod])
  @@index([statusCode])
  @@index([createdAt])
  @@map("user_action_logs")
}

model User {
  id          Int       @id @default(autoincrement()) @map("id")
  taiKhoan    String    @unique @map("tai_khoan")
  matKhauHash String    @map("mat_khau_hash")
  refreshTokenHash String? @map("refresh_token_hash")
  hoVaTen     String    @map("ho_va_ten")
  avatarUrl   String?   @map("avatar_url")
  ngaySinh    DateTime? @map("ngay_sinh")
  gioiTinh    String?   @map("gioi_tinh")
  soDienThoai String    @map("so_dien_thoai")
  soGiayTo    String    @unique @map("so_giay_to")
  diaChi      String?   @map("dia_chi")
  email       String?   @map("email")
  roleCode    String    @default("STAFF") @map("role_code")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  role       Role            @relation(fields: [roleCode], references: [code])
  assignedRoutes Route[] @relation("route_staff")
  actionLogs UserActionLog[]

  @@index([soDienThoai])
  @@index([roleCode])
  @@map("users")
}

model SystemParameter {
  id        Int      @id @default(autoincrement()) @map("id")
  tenThamSo String   @unique @map("ten_tham_so")
  giaTri    String   @map("gia_tri")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenThamSo])
  @@index([isActive])
  @@map("system_parameters")
}

model Permission {
  code      String   @id @map("code")
  label     String   @map("label")
  moduleKey String   @map("module_key")
  moTa      String?  @map("mo_ta")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@index([moduleKey])
  @@index([isActive])
  @@map("permissions")
}

model RolePermission {
  roleCode       String   @map("role_code")
  permissionCode String   @map("permission_code")
  createdAt      DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleCode], references: [code])
  permission Permission @relation(fields: [permissionCode], references: [code])

  @@id([roleCode, permissionCode])
  @@index([permissionCode])
  @@map("role_permissions")
}